# Database
DATABASE_URL=postgresql://eale:eale_secret@localhost:5432/eale

# Seeding
AUTO_SEED=true

# LLM variant generation (optional)
USE_LLM_VARIANTS=false

# LLM context + grading for Chrome Extension (optional)
# Set USE_LLM_CONTEXT=true to have OpenAI infer topic and generate transfer questions
# Set USE_LLM_GRADING=true to have OpenAI grade short-text answers with a rubric
USE_LLM_CONTEXT=false
USE_LLM_GRADING=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
LLM_CACHE_TTL_SECONDS=600

# CORS (comma-separated origins, or "*" for all)
CORS_ORIGINS=*

# Scheduler
SCHEDULER_INTERVAL_SECONDS=60
